        <calculation class='tableau' formula='IF [Calculation_0403259385024517] &gt; 0 THEN&#13;&#10;&quot;Up&quot;&#13;&#10;ELSEIF [Calculation_0403259385024517] &lt; 0 THEN&#13;&#10;&quot;Down&quot;&#13;&#10;ELSE&#13;&#10;&quot;No Change&quot;&#13;&#10;END' />
      </column>
      <column caption='Order Status' datatype='string' name='[Calculation_0403259386425358]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0403259385602056] &gt; 0 THEN&#13;&#10;&quot;Up&quot;&#13;&#10;ELSEIF [Calculation_0403259385602056] &lt; 0 THEN&#13;&#10;&quot;Down&quot;&#13;&#10;ELSE&#13;&#10;&quot;No Change&quot;&#13;&#10;END' />
      </column>
      <column caption='Pervious Year' datatype='string' name='[Calculation_0403259390685199]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;WHEN 2014 THEN &quot;No Previous Year Available&quot;&#13;&#10;WHEN 2015 THEN &quot;2014&quot;&#13;&#10;WHEN 2016 THEN &quot;2015&quot;&#13;&#10;WHEN 2017 THEN &quot;2016&quot;&#13;&#10;END' />
      </column>
      <column caption='Discount CY' datatype='real' name='[Calculation_0403259400155152]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF YEAR([order_date]) = [Parameters].[Parameter 1]&#13;&#10;&#13;&#10;AND&#13;&#10;(&#13;&#10;[Parameters].[Parameter 2] = &quot;All&quot;&#13;&#10;OR [region] = [Parameters].[Parameter 2]&#13;&#10;)&#13;&#10;&#13;&#10;AND&#13;&#10;(&#13;&#10;[Parameters].[Parameter 3] = &quot;All&quot;&#13;&#10;OR [segment] = [Parameters].[Parameter 3]&#13;&#10;)&#13;&#10;&#13;&#10;THEN [discount]&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Discount PY' datatype='real' name='[Calculation_0403259400224785]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF YEAR([order_date]) = [Parameters].[Parameter 1]-1&#13;&#10;&#13;&#10;AND&#13;&#10;&#13;&#10;(&#13;&#10;[Parameters].[Parameter 2] = &quot;All&quot;&#13;&#10;OR [region] = [Parameters].[Parameter 2]&#13;&#10;)&#13;&#10;&#13;&#10;AND&#13;&#10;&#13;&#10;(&#13;&#10;[Parameters].[Parameter 3] = &quot;All&quot;&#13;&#10;OR [segment] = [Parameters].[Parameter 3]&#13;&#10;)&#13;&#10;&#13;&#10;THEN [discount]&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Discount Difference' datatype='real' name='[Calculation_0403259400351762]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Calculation_0403259400155152])&#13;&#10;-&#13;&#10;AVG([Calculation_0403259400224785])' />
      </column>
      <column caption='Discount Status' datatype='string' name='[Calculation_0403259400663059]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0403259400351762] &gt; 0 THEN&#13;&#10;&quot;Up&quot;&#13;&#10;ELSEIF [Calculation_0403259400351762] &lt; 0 THEN&#13;&#10;&quot;Down&quot;&#13;&#10;ELSE&#13;&#10;&quot;No Change&quot;&#13;&#10;END' />
      </column>
      <column caption='Rank Sales' datatype='integer' name='[Calculation_0403259433615380]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(SUM([sales]), &apos;desc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='% Kontribusi Sales' datatype='real' name='[Calculation_0403259460866071]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='SUM([sales]) / SUM({ FIXED [Parameters].[Parameter 1], [Parameters].[Parameter 2], [Parameters].[Parameter 3] : SUM([sales]) })' />
      </column>
      <column caption='% Kontribusi Profit Region' datatype='real' name='[Calculation_0403259467800600]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='SUM([profit]) / SUM({ FIXED [Parameters].[Parameter 1], [Parameters].[Parameter 2], [Parameters].[Parameter 3] : SUM([profit]) })' />
      </column>
      <column caption='Filter Sub Category' datatype='boolean' name='[Calculation_0403259495133212]' role='measure' type='nominal'>
        <calculation class='tableau' formula='RANK(SUM([profit]), &apos;desc&apos;) &lt;= 5 &#13;&#10;OR &#13;&#10;RANK(SUM([profit]), &apos;asc&apos;) &lt;= 5'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Raking Product Name' datatype='integer' name='[Calculation_0403259536961568]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(SUM([Calculation_0403259539689505]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Profit Filter Terpilih' datatype='real' name='[Calculation_0403259539689505]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [product_name], [Calculation_3121251494678528], [Calculation_3121251494830081], [Calculation_3121251495157762], [category] : SUM([profit]) }' />
      </column>
      <column caption='Filter Sub-Category Sukses' datatype='boolean' name='[Calculation_0403259553095715]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF TOTAL(COUNTD([category])) &gt; 1 THEN&#13;&#10;    // Kondisi ALL: Bungkus perbandingan LOD dengan ATTR agar sama-sama agregat&#13;&#10;    ATTR({ FIXED [sub_category], [Calculation_3121251494678528], [Calculation_3121251494830081], [Calculation_3121251495157762] : SUM([profit]) }) &#13;&#10;    = &#13;&#10;    ATTR({ FIXED [Calculation_3121251494678528], [Calculation_3121251494830081], [Calculation_3121251495157762] : MIN({ FIXED [sub_category], [Calculation_3121251494678528], [Calculation_3121251494830081], [Calculation_3121251495157762] : SUM([profit]) }) })&#13;&#10;ELSE&#13;&#10;    // Kondisi per Kategori&#13;&#10;    ATTR({ FIXED [category], [sub_category], [Calculation_3121251494678528], [Calculation_3121251494830081], [Calculation_3121251495157762] : SUM([profit]) })&#13;&#10;    = &#13;&#10;    ATTR({ FIXED [category], [Calculation_3121251494678528], [Calculation_3121251494830081], [Calculation_3121251495157762] : MIN({ FIXED [category], [sub_category], [Calculation_3121251494678528], [Calculation_3121251494830081], [Calculation_3121251495157762] : SUM([profit]) }) })&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Margin Status' datatype='string' name='[Calculation_0721567688818690]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0403259385937931] &gt; 0 THEN&#13;&#10;&quot;Up&quot;&#13;&#10;ELSEIF [Calculation_0403259385937931] &lt; 0 THEN&#13;&#10;&quot;Down&quot;&#13;&#10;ELSE&#13;&#10;&quot;No Change&quot;&#13;&#10;END' />
      </column>
      <column caption='Disclaimer 1' datatype='string' name='[Calculation_1296887773732864]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Klik kategori untuk filter profitabilitas produk &amp; wilayah&quot;' />
      </column>
      <column caption='Disclaimer 2' datatype='string' name='[Calculation_1296887782133761]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Dashboard analisis profitabilitas seluruh kategori produk, sebaran wilayah, serta sub-kategori dengan profit tertinggi dan terendah.&quot;' />
      </column>
      <column caption='Tahun Filter' datatype='boolean' name='[Calculation_3121251494678528]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='YEAR([order_date])=[Parameters].[Parameter 1]' />
      </column>
      <column caption='Region Filter' datatype='boolean' name='[Calculation_3121251494830081]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 2]= &quot;All&quot; THEN TRUE&#13;&#10;ELSE [region]=[Parameters].[Parameter 2]&#13;&#10;END' />
      </column>
      <column caption='Segment Filter' datatype='boolean' name='[Calculation_3121251495157762]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 3]=&quot;All&quot; THEN TRUE&#13;&#10;ELSE [segment]=[Parameters].[Parameter 3]&#13;&#10;END' />
      </column>
      <column caption='Profit Margin' datatype='real' name='[Calculation_3121251506978821]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([profit])/SUM([sales])' />
      </column>
      <column caption='Zero' datatype='integer' name='[Calculation_3121251513057287]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='0' />
      </column>
